* text=auto
CHANGELOG.md merge=union

*.xlsx binary
*.min.js binary
*.min.css binary
doorstop/core/files/templates/html/output/*.js binary
doorstop/core/files/templates/html/tex-mml-chtml.js binary
doorstop/core/tests/files/published*.html binary

# Force LF line endings for YAML and test files to fix Windows tests
*.yml text eol=lf
doorstop/core/tests/files/** text eol=lf

# Keep these as-is (don't normalize)
*.txt  -text
*.md   -text
*.html -text
*.csv  -text
*.tsv  -text